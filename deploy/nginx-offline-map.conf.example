# Copy this location block into the production frontend server.
# Synchronize frontend/map/tiles_street to /opt/cabin/maps/tiles_street separately.
location ~ ^/offline-map/(\d+)/(\d+)/(\d+)\.png$ {
    alias /opt/cabin/maps/tiles_street/$1/$2/$3.png;
    access_log off;
    log_not_found off;
    expires 30d;
    add_header Cache-Control "public, max-age=2592000, immutable";
}
